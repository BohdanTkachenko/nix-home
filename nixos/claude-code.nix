# Claude Code NixOS module.
# Copies managed settings and MCP config from the primary user's home directory
# to /etc/claude-code/. The files are generated by home-manager.
# All Claude Code configuration is defined in home/programs/ai/claude-code.nix.
{
  config,
  lib,
  pkgs,
  ...
}:
let
  primaryUser = builtins.head (builtins.attrNames config.my.users);
  hmCfg = config.home-manager.users.${primaryUser}.my.claude-code;
  hmFiles = config.home-manager.users.${primaryUser}.home.file;
  homeDir = "/home/${primaryUser}";
in
{
  config = lib.mkIf hmCfg.enable {
    systemd.services.claude-code-managed-settings = {
      description = "Copy Claude Code managed config to /etc";
      after = [ "home-manager-${primaryUser}.service" ];
      wants = [ "home-manager-${primaryUser}.service" ];
      wantedBy = [ "multi-user.target" ];
      restartTriggers = [
        hmFiles.".claude/managed-settings.json".text
      ];
      serviceConfig = {
        Type = "oneshot";
        ExecStart = lib.getExe (pkgs.writeShellScriptBin "copy-claude-managed" ''
          mkdir -p /etc/claude-code
          cp ${homeDir}/.claude/managed-settings.json /etc/claude-code/managed-settings.json
          cp ${homeDir}/.claude/managed-mcp.json /etc/claude-code/managed-mcp.json
          chmod 644 /etc/claude-code/managed-settings.json /etc/claude-code/managed-mcp.json
        '');
      };
    };
  };
}
