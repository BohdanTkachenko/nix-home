# Claude Code NixOS module.
# Symlinks /etc/claude-code/managed-settings.json to the primary user's
# ~/.claude/managed.json, which is generated by home-manager.
# All Claude Code configuration is defined in home/programs/ai/claude-code.nix.
{
  config,
  lib,
  ...
}:
let
  primaryUser = builtins.head (builtins.attrNames config.my.users);
  hmCfg = config.home-manager.users.${primaryUser}.my.claude-code;
in
{
  config = lib.mkIf hmCfg.enable {
    environment.etc."claude-code/managed-settings.json" = {
      source = "/home/${primaryUser}/.claude/managed.json";
    };
  };
}
