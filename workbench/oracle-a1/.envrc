# Inherit the repo-root flake devShell.
source_up

# OCI S3 backend credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY).
dotenv_if_exists .env

# OCI's S3 API rejects the AWS SDK's default integrity checksums; restrict them
# to when an operation requires them so the s3 backend works.
export AWS_REQUEST_CHECKSUM_CALCULATION=when_required
export AWS_RESPONSE_CHECKSUM_VALIDATION=when_required
